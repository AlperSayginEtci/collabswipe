generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. AUTHENTICATION (Better Auth Uyumlu)
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  surname       String?
  username      String?   @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user") // user, admin, company
  sector        String?   // Sector for companies
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  strikeCount   Int       @default(0)
  isShadowbanned Boolean  @default(false)
  muteExpires   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth Relations
  sessions      Session[]
  accounts      Account[]

  // Feature Relations
  profile            Profile?
  sentConnections    Connection[]    @relation("SentConnections")
  receivedConnections Connection[]   @relation("ReceivedConnections")
  followers          Follows[]       @relation("Following")
  following          Follows[]       @relation("Followers")
  postedJobs         JobPosting[]
  jobApplications    JobApplication[]
  posts              Post[]
  likedPosts         Like[]
  comments           Comment[]
  commentLikes       CommentLike[]
  conversations      Participant[]
  messages           Message[]
  announcements      Announcement[]
  certificatesIssued Certificate[]   @relation("OrganizationCertificates")
  messageReactions   MessageReaction[]
  reportsMade        Report[]        @relation("ReportsMade")
  notifications      Notification[]
  editRequests       Post[]          @relation("EditRequests")
  tickets            Ticket[]
  ticketMessages     TicketMessage[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==========================================
// 2. PROFILE & NETWORK
// ==========================================

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  profileName String?
  bio         String?
  links       String[] @default([])
  location    String?
  age         Int?
  banner      String?  // Image URL
  isPrivate   Boolean  @default(false) // If true, followers must be approved

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  experiences  Experience[]
  educations   Education[]
  certificates Certificate[]
  languages    UserLanguage[]
  skills       UserSkill[]
}

model Connection {
  requesterId String
  addresseeId String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester   User @relation("SentConnections", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User @relation("ReceivedConnections", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@id([requesterId, addresseeId])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Follows {
  followerId  String
  followingId String
  isAccepted  Boolean  @default(true) // False means it's a pending request
  createdAt   DateTime @default(now())

  follower    User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

// ==========================================
// 3. EXPERIENCE, EDUCATION & CERTS
// ==========================================

model Experience {
  expId     String         @id @default(cuid())
  profileId String
  type      ExperienceType
  title     String
  corp      String
  startDate DateTime
  endDate   DateTime?
  location  String?
  locType   LocationType?
  desc      String?
  skillId   String?

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     Skill?  @relation(fields: [skillId], references: [skillId], onDelete: SetNull)
}

enum ExperienceType {
  INTERNSHIP
  WORK
}

enum LocationType {
  REMOTE
  ONSITE
  HYBRID
}

model Education {
  eduId       String    @id @default(cuid())
  profileId   String
  instName    String
  instDegree  String?
  startDate   DateTime
  endDate     DateTime?
  instProgram String?
  instEvents  String?
  instDesc    String?
  skillId     String?

  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill       Skill?  @relation(fields: [skillId], references: [skillId], onDelete: SetNull)
}

model Certificate {
  cerId         String    @id @default(cuid())
  profileId     String
  title         String
  org           String
  orgID         String?   // If organization is a user on the platform
  startDate     DateTime
  endDate       DateTime?
  competencyURL String?
  competencyId  String?
  skillId       String?

  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  organization  User?   @relation("OrganizationCertificates", fields: [orgID], references: [id], onDelete: SetNull)
  skill         Skill?  @relation(fields: [skillId], references: [skillId], onDelete: SetNull)
}

// ==========================================
// 4. SKILLS & LANGUAGES
// ==========================================

model Skill {
  skillId   String @id @default(cuid())
  skillName String @unique

  userSkills   UserSkill[]
  jobPostings  JobPosting[] @relation("JobRequirements")
  experiences  Experience[]
  educations   Education[]
  certificates Certificate[]
}

model UserSkill {
  profileId String
  skillId   String

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [skillId], onDelete: Cascade)

  @@id([profileId, skillId])
}

model Language {
  id          String         @id @default(cuid())
  name        String         @unique
  userLanguages UserLanguage[]
}

model UserLanguage {
  profileId   String
  languageId  String
  proficiency String // A1, A2, B1, etc.

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([profileId, languageId])
}

// ==========================================
// 5. JOBS
// ==========================================

model JobPosting {
  id          String       @id @default(cuid())
  publisherId String
  title       String
  description String
  type        JobType
  status      JobStatus    @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  publisher   User             @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  requirements Skill[]         @relation("JobRequirements")
  applications JobApplication[]
}

enum JobType {
  FREELANCE
  CORPORATE
}

enum JobStatus {
  OPEN
  CLOSED
  BANNED
}

model JobApplication {
  id          String            @id @default(cuid())
  jobId       String
  applicantId String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  createdAt   DateTime          @default(now())

  job         JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant   User       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ==========================================
// 6. SOCIAL & CONTENT
// ==========================================

model Post {
  id             String   @id @default(cuid())
  authorId       String
  content        String
  mediaUrl       String?
  originalPostId String?
  isBanned       Boolean  @default(false)
  isQuarantined  Boolean  @default(false)
  editRequestedAt DateTime?
  editRequestedBy String?
  createdAt      DateTime @default(now())

  author         User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  adminRequester User?     @relation("EditRequests", fields: [editRequestedBy], references: [id], onDelete: SetNull)
  originalPost   Post?     @relation("Reposts", fields: [originalPostId], references: [id], onDelete: SetNull)
  reposts        Post[]    @relation("Reposts")
  likes          Like[]
  comments       Comment[]
}

model Like {
  postId String
  userId String
  type   String @default("LIKE")

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model Comment {
  id              String   @id @default(cuid())
  postId          String
  authorId        String
  content         String
  createdAt       DateTime @default(now())
  parentCommentId String?

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[]     @relation("CommentReplies")
  likes         CommentLike[]
}

model CommentLike {
  commentId String
  userId    String
  type      String @default("LIKE")

  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
}

// ==========================================
// 7. CHAT & MESSAGING
// ==========================================

model Conversation {
  id            String   @id @default(cuid())
  isGroup       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())

  participants Participant[]
  messages     Message[]
}

model Participant {
  conversationId String
  userId         String
  lastReadAt     DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isDeleted      Boolean  @default(false)
  isEdited       Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions      MessageReaction[]
}

model MessageReaction {
  messageId String
  userId    String
  emoji     String

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
}

// ==========================================
// 8. ADMIN
// ==========================================

model Announcement {
  id        String   @id @default(cuid())
  adminId   String
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  admin     User @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  reason      String
  status      ReportStatus     @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reporter    User @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
}

enum ReportTargetType {
  USER
  POST
  COMMENT
  JOB
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ==========================================
// 9. SUPPORT TICKETS
// ==========================================

model Ticket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  category  String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  content   String
  attachmentUrls String[] @default([])
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User   @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
